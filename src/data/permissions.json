{
  "roles": {
    "admin": {
      "label": "Administrador",
      "description": "Acesso total ao sistema",
      "permissions": [
        "view:home",
        "view:clients",
        "view:dashboard",
        "view:members",
        "view:reports",
        "view:admin",
        "tasks:read",
        "tasks:create",
        "tasks:update",
        "tasks:delete"
      ]
    },
    "user": {
      "label": "Usuário",
      "description": "Acesso limitado aos clientes associados",
      "permissions": [
        "view:home",
        "view:clients",
        "view:dashboard",
        "view:members",
        "view:reports",
        "tasks:read",
        "tasks:create",
        "tasks:update",
        "tasks:delete"
      ]
    }
  },
  "features": {
    "dashboard": {
      "label": "Dashboard",
      "description": "Visualização de demandas e calendário",
      "requiresClient": true,
      "permission": "view:dashboard",
      "roles": ["admin", "user"]
    },
    "reports": {
      "label": "Relatórios",
      "description": "Análise e relatórios das demandas",
      "requiresClient": true,
      "permission": "view:reports",
      "roles": ["admin", "user"]
    },
    "members": {
      "label": "Equipe",
      "description": "Visualização da capacidade da equipe",
      "requiresClient": true,
      "permission": "view:members",
      "roles": ["admin", "user"]
    },
    "clients": {
      "label": "Meus Clientes",
      "description": "Gerenciar clientes associados",
      "requiresClient": false,
      "permission": "view:clients",
      "roles": ["admin", "user"]
    },
    "admin": {
      "label": "Administração",
      "description": "Painel de administração",
      "requiresClient": false,
      "permission": "view:admin",
      "roles": ["admin"]
    }
  },
  "accessRules": {
    "noClient": {
      "allowedViews": ["clients"],
      "message": "Você não possui clientes associados. Por favor, contacte um administrador para solicitar acesso."
    },
    "noClientSelected": {
      "allowedViews": ["clients"],
      "message": "Selecione um cliente para acessar as funcionalidades."
    }
  }
}
