VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_ALLOWED_DOMAIN=yourdomain.com
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redirect OAuth seguro (allowlist)
VITE_REDIRECT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://homol.seudominio.com,https://app.seudominio.com
VITE_REDIRECT_ALLOWED_PATHS=/,/auth/callback

# Expiracao maxima de sessao em horas (minimo efetivo: 48)
VITE_SESSION_MAX_AGE_HOURS=168
